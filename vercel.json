{
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    { "source": "/brokercontrol", "destination": "/products/brokercontrol/", "permanent": true },
    { "source": "/brokercontrol/", "destination": "/products/brokercontrol/", "permanent": true },
    { "source": "/soc", "destination": "/products/soc/", "permanent": true },
    { "source": "/soc/", "destination": "/products/soc/", "permanent": true },
    { "source": "/cleanloop", "destination": "/products/cleanloop/", "permanent": true },
    { "source": "/cleanloop/", "destination": "/products/cleanloop/", "permanent": true },
    { "source": "/ghostwear", "destination": "/brands/ghostwear/", "permanent": true },
    { "source": "/ghostwear/", "destination": "/brands/ghostwear/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
